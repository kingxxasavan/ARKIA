# Copy this to .env for local use, OR add each one to Replit Secrets (padlock icon)
# You only need the keys for providers you actually use

ANTHROPIC_KEY=sk-ant-...
OPENAI_KEY=sk-...
OLLAMA_KEY=your-ollama-cloud-key
OPENROUTER_KEY=sk-or-...

# ── Server-side locked system prompt (optional) ──
# The most reliable way to enforce a prompt for everyone (users can't bypass it
# by editing the page). Set both:
# LOCK_SYSTEM_PROMPT=1
# LOCKED_SYSTEM_PROMPT=You are ARIA. Always follow these rules ...

# Optional: let the server read the admin panel's locked prompt from Realtime
# Database instead of the env var above. Public RTDB reads need no key, so just
# point this at your database URL (Firebase Console → Realtime Database).
# FIREBASE_DB_URL=https://arikia-default-rtdb.firebaseio.com
